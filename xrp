<script>
let amountStr = '';
let currentOrder = null;
let es = null;
let sales = [];
let xrpPrice = null;
let mode = 'xrp'; // 'xrp' or 'usd'

// ── mode toggle ──
function setMode(m) {
  mode = m;
  document.getElementById('mode-xrp').className = 'mode-btn' + (m === 'xrp' ? ' active-xrp' : '');
  document.getElementById('mode-usd').className = 'mode-btn' + (m === 'usd' ? ' active-usd' : '');
  document.getElementById('amount-label').textContent = m === 'usd' ? 'Amount (USD)' : 'Amount (XRP)';
  amountStr = '';
  updateAmountDisplay();
}

// ── price ──
async function fetchPrice() {
  try {
    const r = await fetch('/price');
    const d = await r.json();
    if (d.usd) {
      xrpPrice = d.usd;
      document.getElementById('price-display').textContent = '1 XRP = $' + xrpPrice.toFixed(4);
      updateAmountDisplay();
      // enable USD mode button only when price is available
      document.getElementById('mode-usd').disabled = false;
    }
  } catch {}
}
document.getElementById('mode-usd').disabled = true;
fetchPrice();
setInterval(fetchPrice, 60000);

// ── load today's sales on startup ──
async function loadTodaySales() {
  try {
    const r = await fetch('/history');
    const d = await r.json();
    if (d.sales && d.sales.length) {
      sales = d.sales.map(s => ({
        tag:    s.tag,
        amount: s.amount,
        label:  s.label || '',
        sender: s.sender || '',
        time:   new Date(s.time * 1000),
      }));
      renderHistory();
    }
  } catch {}
}
loadTodaySales();

function toUSD(xrp) {
  if (!xrpPrice || !xrp) return '';
  return '$' + (xrp * xrpPrice).toFixed(2);
}

function toXRP(usd) {
  if (!xrpPrice || !usd) return null;
  return Math.ceil((usd / xrpPrice) * 1000000) / 1000000; // round up to nearest drop
}

// ── keypad ──
document.getElementById('keypad').addEventListener('click', e => {
  const key = e.target.closest('.key');
  if (!key) return;
  const v = key.dataset.v;
  if (v === 'del') {
    amountStr = amountStr.slice(0,-1);
  } else if (v === '.') {
    if (!amountStr.includes('.')) amountStr += (amountStr === '' ? '0.' : '.');
  } else {
    // USD mode: max 2 decimal places
    if (mode === 'usd' && amountStr.includes('.')) {
      const decimals = amountStr.split('.')[1];
      if (decimals && decimals.length >= 2) { updateAmountDisplay(); return; }
    }
    if (amountStr.length < 10) amountStr += v;
  }
  updateAmountDisplay();
});

function updateAmountDisplay() {
  const el      = document.getElementById('amount-display');
  const usdEl   = document.getElementById('amount-usd');
  const suffixEl = document.getElementById('amount-suffix');
  const btn     = document.getElementById('charge-btn');
  const val     = parseFloat(amountStr);

  if (!amountStr || val <= 0) {
    el.innerHTML = '0<span class="amount-suffix" id="amount-suffix">' + (mode === 'usd' ? 'USD' : 'XRP') + '</span>';
    el.classList.add('empty');
    usdEl.textContent = '';
    btn.disabled = true;
  } else {
    const suffix = mode === 'usd' ? 'USD' : 'XRP';
    el.innerHTML = amountStr + '<span class="amount-suffix" id="amount-suffix">' + suffix + '</span>';
    el.classList.remove('empty');

    if (mode === 'usd') {
      const xrpVal = toXRP(val);
      usdEl.textContent = xrpVal ? '≈ ' + xrpVal.toFixed(6) + ' XRP' : '';
      usdEl.style.color = '#7eb8f7';
    } else {
      const usdVal = toUSD(val);
      usdEl.textContent = usdVal ? '≈ ' + usdVal : '';
      usdEl.style.color = '#22c55e';
    }
    btn.disabled = false;
  }
}

// ── charge ──
document.getElementById('charge-btn').addEventListener('click', async () => {
  const inputVal = parseFloat(amountStr);
  if (!inputVal || inputVal <= 0) return;
  const label = document.getElementById('label-input').value.trim();

  // convert to XRP if in USD mode
  let xrpAmount, usdAmount;
  if (mode === 'usd') {
    usdAmount = inputVal;
    xrpAmount = toXRP(inputVal);
    if (!xrpAmount) { alert('Price not available — cannot convert USD to XRP'); return; }
    xrpAmount = Math.round(xrpAmount * 1000000) / 1000000;
  } else {
    xrpAmount = inputVal;
    usdAmount = xrpPrice ? inputVal * xrpPrice : null;
  }

  const res = await fetch('/order', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ amount: xrpAmount, label })
  });
  const order = await res.json();
  currentOrder = order;

  document.getElementById('state-idle').style.display = 'none';
  document.getElementById('state-waiting').style.display = 'block';
  document.getElementById('state-paid').style.display = 'none';

  document.getElementById('qr-box').innerHTML = '';
  new QRCode(document.getElementById('qr-box'), {
    text: order.uri,
    width: 210, height: 210,
    colorDark: '#000000', colorLight: '#ffffff',
    correctLevel: QRCode.CorrectLevel.M
  });

  document.getElementById('si-amount').textContent = xrpAmount + ' XRP';
  if (usdAmount) {
    document.getElementById('si-usd').textContent = '$' + usdAmount.toFixed(2);
    document.getElementById('si-usd-row').style.display = 'flex';
  }
  if (label) {
    document.getElementById('si-label').textContent = label;
    document.getElementById('si-label-row').style.display = 'flex';
  } else {
    document.getElementById('si-label-row').style.display = 'none';
  }
  document.getElementById('si-tag').textContent = order.tag;
  document.getElementById('si-addr').textContent = order.address;

  amountStr = '';
  document.getElementById('label-input').value = '';
  updateAmountDisplay();

  if (es) { clearInterval(es); es = null; }
  es = setInterval(async () => {
    try {
      const r = await fetch('/status?tag=' + order.tag);
      const d = await r.json();
      if (d.status === 'paid') {
        clearInterval(es); es = null;
        handlePaid({ tag: order.tag, amount: d.amount, sender: d.sender, label: order.label });
      }
    } catch {}
  }, 1000);
});

function handlePaid(data) {
  if (es) { clearInterval(es); es = null; }
  document.getElementById('state-waiting').style.display = 'none';
  document.getElementById('state-paid').style.display = 'block';

  const usdVal = toUSD(data.amount);
  document.getElementById('paid-amount').textContent = data.amount + ' XRP received';
  document.getElementById('paid-usd').textContent = usdVal ? '≈ ' + usdVal : '';
  document.getElementById('paid-label').textContent = data.label || '';
  document.getElementById('paid-from').textContent = 'From: ' + data.sender;

  sales.unshift({ amount: data.amount, label: data.label || '', tag: data.tag, time: new Date() });
  renderHistory();
}

document.getElementById('new-sale-btn').addEventListener('click', resetToIdle);
document.getElementById('cancel-btn').addEventListener('click', async () => {
  if (currentOrder) {
    await fetch('/cancel', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ tag: currentOrder.tag })
    }).catch(() => {});
  }
  if (es) { clearInterval(es); es = null; }
  document.getElementById('qr-box').innerHTML = '';
  resetToIdle();
});

function resetToIdle() {
  currentOrder = null;
  amountStr = '';
  updateAmountDisplay();
  document.getElementById('label-input').value = '';
  document.getElementById('state-idle').style.display = 'block';
  document.getElementById('state-waiting').style.display = 'none';
  document.getElementById('state-paid').style.display = 'none';
  document.getElementById('si-usd-row').style.display = 'none';
  document.getElementById('si-label-row').style.display = 'none';
}

function renderHistory() {
  const el = document.getElementById('history-list');
  if (!sales.length) {
    el.innerHTML = '<span class="no-history">No sales yet</span>';
    document.getElementById('daily-total').innerHTML = '';
    return;
  }

  // daily total
  const todayStr = new Date().toDateString();
  const todaySales = sales.filter(s => s.time.toDateString() === todayStr);
  const totalXRP = todaySales.reduce((a, s) => a + s.amount, 0);
  const totalUSD = toUSD(totalXRP);
  document.getElementById('daily-total').innerHTML =
    'Today: <span class="total-xrp">' + totalXRP.toFixed(4) + ' XRP</span>' +
    (totalUSD ? ' <span class="total-usd">' + totalUSD + '</span>' : '');

  el.innerHTML = sales.slice(0,20).map(s => {
    const u = toUSD(s.amount);
    return `<div class="history-item">
      <span class="hi-label ${s.label ? '' : 'no-label'}">${s.label || 'no label'}</span>
      <span class="hi-amount">+${s.amount} XRP</span>
      ${u ? `<span class="hi-usd">${u}</span>` : '<span></span>'}
      <span class="hi-time">${s.time.toLocaleTimeString()}</span>
    </div>`;
  }).join('');
}

