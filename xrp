def cmd_pos(args):
    import threading
    import random
    from http.server import ThreadingHTTPServer, BaseHTTPRequestHandler
    from urllib.parse import urlparse, parse_qs

    address    = load_address()
    port       = args.port or 7743
    merchant   = args.name or "XRP Point of Sale"
    orders_file = CONFIG_DIR / "pos_orders.json"

    def load_orders():
        if orders_file.exists():
            try: return {int(k): v for k, v in json.loads(orders_file.read_text()).items()}
            except: pass
        return {}

    def save_orders():
        orders_file.write_text(json.dumps({str(k): v for k, v in orders.items()}, indent=2))

    orders = load_orders()

    def get_balance():
        try:
            client = JsonRpcClient(get_node())
            resp   = client.request(AccountInfo(account=address, ledger_index="validated"))
            drops  = int(resp.result["account_data"]["Balance"])
            return float(drops_to_xrp(str(drops)))
        except:
            return None

    def xrpl_watcher():
        def handle(tx):
            meta    = tx.get("meta", {})
            tx_data = tx.get("transaction", tx)
            if tx_data.get("TransactionType") != "Payment":
                return
            if tx_data.get("Destination") != address:
                return
            amt = tx_data.get("Amount", "0")
            if isinstance(amt, dict):
                return
            if meta.get("TransactionResult") != "tesSUCCESS":
                return
            amount_xrp = float(drops_to_xrp(amt))
            tag        = tx_data.get("DestinationTag")
            sender     = tx_data.get("Account", "unknown")
            tx_hash    = tx_data.get("hash", "")
            log_tx(tx_hash, "in", amount_xrp, sender, tag, None, int(time.time()), 0)
            if tag in orders:
                if orders[tag]["status"] == "cancelled":
                    return
                orders[tag]["status"] = "paid"
                orders[tag]["sender"] = sender
                orders[tag]["paid_at"] = int(time.time())
                save_orders()

        while True:
            try:
                with WebsocketClient(get_ws_node()) as ws:
                    ws.send(Subscribe(accounts=[address]))
                    for msg in ws:
                        if msg.get("type") == "transaction":
                            handle(msg)
            except Exception:
                time.sleep(3)

    class POSHandler(BaseHTTPRequestHandler):
        def log_message(self, *a): pass

        def do_GET(self):
            p = urlparse(self.path)

            if p.path == '/':
                self.send_response(200)
                self.send_header("Content-Type","text/html; charset=utf-8")
                self.end_headers()
                html = POS_HTML.replace("⬡ XRP Point of Sale", f"⬡ {merchant}")
                self.wfile.write(html.encode())

            elif p.path == '/balance':
                bal   = get_balance()
                price = get_xrp_price()
                self.json({"balance": bal, "usd": round(bal * price, 2) if bal and price else None, "price": price})

            elif p.path == '/price':
                price = get_xrp_price()
                self.json({"usd": price})

            elif p.path == '/history':
                today_start = datetime.now(tz=timezone.utc).replace(hour=0, minute=0, second=0, microsecond=0).timestamp()
                paid = []
                for tag, o in orders.items():
                    if o.get("status") != "paid": continue
                    ts = o.get("paid_at") or o.get("created") or 0
                    # include if we have no timestamp (legacy orders) or if it's today
                    if ts == 0 or ts >= today_start:
                        paid.append({
                            "tag":    tag,
                            "amount": o.get("amount", 0),
                            "label":  o.get("label", ""),
                            "sender": o.get("sender", ""),
                            "time":   ts,
                        })
                paid.sort(key=lambda x: x["time"], reverse=True)
                self.json({"sales": paid})

            elif p.path == '/status':
                tag = int(parse_qs(p.query).get("tag",["0"])[0])
                order = orders.get(tag, {})

                # fast path — already confirmed by watcher
                if order.get("status") == "paid":
                    self.json({"status":"paid","amount":order.get("amount",0),"sender":order.get("sender",""),"label":order.get("label","")})
                    return

                if order.get("status") == "cancelled":
                    self.json({"status":"cancelled"})
                    return

                # live check — query ledger directly for recent inbound txs
                if order.get("status") == "pending":
                    try:
                        client  = JsonRpcClient(get_node())
                        resp    = client.request(AccountTx(account=address, limit=10, ledger_index_min=-1, ledger_index_max=-1))
                        for entry in resp.result.get("transactions", []):
                            tx   = entry.get("tx_json", entry.get("tx", entry.get("transaction", {})))
                            meta = entry.get("meta", {})
                            if tx.get("TransactionType") != "Payment": continue
                            if tx.get("Destination") != address: continue
                            if meta.get("TransactionResult") != "tesSUCCESS": continue
                            amt = tx.get("Amount") or tx.get("DeliverMax", "0")
                            if isinstance(amt, dict): continue
                            tx_tag    = tx.get("DestinationTag")
                            tx_amount = float(drops_to_xrp(str(amt)))
                            tx_sender = tx.get("Account", "")
                            tx_hash   = entry.get("hash", tx.get("hash", ""))
                            # tag is a unique order ID — if it matches, accept unconditionally
                            # fall back to amount-only match if sender sent without a tag
                            tag_match    = (tx_tag is not None and tx_tag == tag)
                            amount_match = (tx_tag is None and abs(tx_amount - order.get("amount", 0)) < 0.01)
                            if tag_match or amount_match:
                                orders[tag]["status"] = "paid"
                                orders[tag]["sender"] = tx_sender
                                orders[tag]["paid_at"] = int(time.time())
                                save_orders()
                                log_tx(tx_hash, "in", tx_amount, tx_sender, tx_tag, None, int(time.time()), 0)
                                self.json({"status":"paid","amount":tx_amount,"sender":tx_sender,"label":order.get("label","")})
                                return
                    except Exception:
                        pass

                self.json({"status": order.get("status","unknown"), "amount": order.get("amount",0), "sender": ""})

            else:
                self.send_response(404)
                self.end_headers()

        def do_POST(self):
            if self.path == '/order':
                length = int(self.headers.get("Content-Length",0))
                body   = json.loads(self.rfile.read(length))
                amount = float(body.get("amount", 0))
                label  = str(body.get("label", ""))[:64]
                tag    = random.randint(10000, 9999999)
                while tag in orders:
                    tag = random.randint(10000, 9999999)
                orders[tag] = {"amount": amount, "label": label, "status": "pending", "sender": None, "created": int(time.time())}
                save_orders()
                uri = make_xrpl_uri(address, amount, tag)
                self.json({"tag": tag, "amount": amount, "label": label, "address": address, "uri": uri})

            elif self.path == '/cancel':
                length = int(self.headers.get("Content-Length",0))
                body   = json.loads(self.rfile.read(length))
                tag    = int(body.get("tag", 0))
                if tag in orders and orders[tag]["status"] == "pending":
                    orders[tag]["status"] = "cancelled"
                    save_orders()
                self.json({"ok": True})
            else:
                self.send_response(404)
                self.end_headers()

        def json(self, data):
            payload = json.dumps(data).encode()
            self.send_response(200)
            self.send_header("Content-Type","application/json")
            self.send_header("Content-Length", len(payload))
            self.end_headers()
            self.wfile.write(payload)

    t = threading.Thread(target=xrpl_watcher, daemon=True)
    t.start()

    # LAN IP detection
    import socket
    lan_ip = None
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        lan_ip = s.getsockname()[0]
        s.close()
    except:
        pass

    server = ThreadingHTTPServer(("0.0.0.0", port), POSHandler)
    lan_line = f"LAN:     [bold green]http://{lan_ip}:{port}[/bold green]  [dim](tablets, phones)[/dim]\n" if lan_ip and args.lan else ""
    console.print(Panel(
        f"Address: [bold cyan]{address}[/bold cyan]\n"
        f"URL:     [bold green]http://localhost:{port}[/bold green]\n"
        + lan_line +
        f"\n[dim]Open the URL in any browser on this machine.\n"
        f"Listening for payments on XRPL...[/dim]",
        title=f"XRP Point of Sale{' — ' + args.name if args.name else ''}",
        expand=False
    ))

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        console.print("\n[dim]POS stopped.[/dim]")


